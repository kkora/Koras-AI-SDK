root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.{json,yml,yaml,xml,csproj,props,targets,config}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.cs]
# --- Style: modern, file-scoped, var-friendly ---
csharp_style_namespace_declarations = file_scoped:error
csharp_style_var_for_built_in_types = true:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = true:suggestion
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = true:suggestion
csharp_style_prefer_primary_constructors = true:suggestion
csharp_prefer_braces = true:suggestion
csharp_style_prefer_switch_expression = true:suggestion
csharp_using_directive_placement = outside_namespace:error
dotnet_sort_system_directives_first = true

# --- Naming ---
dotnet_naming_rule.interfaces_begin_with_i.severity = error
dotnet_naming_rule.interfaces_begin_with_i.symbols = interface_symbols
dotnet_naming_rule.interfaces_begin_with_i.style = prefix_i
dotnet_naming_symbols.interface_symbols.applicable_kinds = interface
dotnet_naming_style.prefix_i.capitalization = pascal_case
dotnet_naming_style.prefix_i.required_prefix = I

dotnet_naming_rule.private_fields_underscore.severity = suggestion
dotnet_naming_rule.private_fields_underscore.symbols = private_fields
dotnet_naming_rule.private_fields_underscore.style = underscore_camel
dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_style.underscore_camel.capitalization = camel_case
dotnet_naming_style.underscore_camel.required_prefix = _

# --- Qualification ---
dotnet_style_qualification_for_field = false:suggestion
dotnet_style_qualification_for_property = false:suggestion
dotnet_style_qualification_for_method = false:suggestion

# --- Analyzer severities ---
# Async hygiene
dotnet_diagnostic.CA2007.severity = none          # ConfigureAwait enforced in src .editorconfig
dotnet_diagnostic.CA1849.severity = warning       # call async methods when in async method
dotnet_diagnostic.CA1068.severity = error         # CancellationToken parameters must come last
dotnet_diagnostic.CA2016.severity = error         # forward CancellationToken
# Design
dotnet_diagnostic.CA1032.severity = none          # standard exception ctors not required (AiException is deliberate)
dotnet_diagnostic.CA1848.severity = none          # LoggerMessage used where hot; not enforced repo-wide
dotnet_diagnostic.IDE0005.severity = warning      # remove unnecessary usings

[src/**.cs]
dotnet_diagnostic.CA2007.severity = error         # ConfigureAwait(false) required in library code

[{tests,samples,benchmarks}/**.cs]
dotnet_diagnostic.CA2007.severity = none
csharp_style_expression_bodied_methods = when_on_single_line:silent
